# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret-key
JWT_SECRET_KEY=change-me-to-another-random-key

# Database (SQLite path relative to backend/)
DATABASE_URL=sqlite:///bkwitten.db

# CORS_ORIGINS: comma-separated list of allowed origins in production
# Example: CORS_ORIGINS=https://app.bk-witten.de,https://bk-witten.de
CORS_ORIGINS=*

# WebUntis school server (e.g. niobe.webuntis.com)
WEBUNTIS_SERVER=bk-witten.webuntis.com
WEBUNTIS_SCHOOL=bk-witten
